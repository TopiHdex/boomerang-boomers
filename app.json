{
  "expo": {
    "name": "boomerang-boomers",
    "slug": "boomerang-boomers",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "boomerangboomers",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/ios.icon",
      "infoPlist": {
        "UIBackgroundModes": [
          "location",
          "location"
        ],
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.topihdex.boomerangboomers"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E2E3E3",
        "foregroundImage": "./assets/android.png",
        "monochromeImage": "./assets/android.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.topihdex.boomerangboomers",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "@clerk/expo",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#34c64c",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Boomerang necesita tu ubicación para compartirla con clientes durante las entregas.",
          "locationWhenInUsePermission": "Boomerang necesita tu ubicación para las entregas.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e3fd1425-feb6-4d67-83aa-088d7dbe4af9"
      }
    }
  }
}
